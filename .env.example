# Application
APP_NAME=ai-accountability-agent
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/accountability.db

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Twilio SMS
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890
USER_PHONE_NUMBER=+1234567890

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_USER_ID=U1234567890

# Asana (Personal Access Token)
ASANA_ACCESS_TOKEN=your-pat-token

# Notion (Integration Token)
NOTION_API_KEY=your-integration-token

# Spark Email MCP (multi-account email via MCP server)
SPARK_EMAIL_COMMAND=python
SPARK_EMAIL_ARGS=["../spark_email_mcp/server.py"]

# Anthropic (for AI features)
ANTHROPIC_API_KEY=your-api-key

# Digital Twin API (Craig-shaped decisions instead of generic Claude)
TWIN_API_ENABLED=false
TWIN_API_URL=http://192.168.5.90:8100
TWIN_API_KEY=

# Scheduling
MORNING_BRIEFING_TIME=07:00
TIMEZONE=Australia/Sydney
